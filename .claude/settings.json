{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(just:*)",
      "Bash(swift build)",
      "Bash(swift test)",
      "Bash(swift package:*)",
      "Bash(swiftformat:*)",
      "Bash(swiftlint:*)",
      "Bash(xcbeautify:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo view:*)"
    ],
    "deny": [
      "Read(./**/*.p12)",
      "Read(./**/*.mobileprovision)",
      "Read(./.env)",
      "Read(./**/secrets/**)"
    ]
  },
  "env": {
    "ORCHARD_STAGE": "skeleton"
  }
}
